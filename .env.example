# Reversegent environment variables
# Copy to .env and fill in your values.

# Required: OpenAI API key for the reasoning LLM
OPENAI_API_KEY=sk-...

# Optional overrides (can also be set via CLI flags)
# REVERSEGENT_TARGET_BASE_URL=http://localhost:8000/v1
# REVERSEGENT_TARGET_MODEL=llama-3.1-8b
# REVERSEGENT_TARGET_API_KEY=not-needed
# REVERSEGENT_REASONING_MODEL=gpt-4o
# REVERSEGENT_MAX_ITERATIONS=20
# REVERSEGENT_CONVERGENCE_THRESHOLD=0.85
